# DDoS Detection System - Environment Variables
# Copy to .env and fill values before use
# Local: docker-compose.prod.yml
# Cloud: K8s Secrets / AWS SSM (external-secrets)

# ===== Core Services =====
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_FLOWS=network_flows_prod
KAFKA_TOPIC_ALERTS=ddos_alerts_prod
KAFKA_TOPIC_METRICS=ddos_metrics_prod
KAFKA_GROUP_ID=ddos-detection-group
KAFKA_AUTO_OFFSET_RESET=earliest

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== API / Webhook =====
API_PORT=8000
API_KEY=your-super-secret-api-key-change-me
ENVIRONMENT=production

# ===== Grafana / Monitoring =====
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASS=admin  # CHANGE IMMEDIATELY
PROMETHEUS_PORT=9090

# ===== Alertmanager / Notifications =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
GMAIL_USERNAME=your@gmail.com
GMAIL_PASSWORD=your-app-password
PAGERDUTY_INTEGRATION_KEY=

# ===== AWS Cloud (EKS/ECR/SSM) =====
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
ECR_REPO=ddos-system
IMAGE_TAG=v1.0.0
K8S_NAMESPACE=ddos-system
HELM_RELEASE=ddos-system
EKS_CLUSTER_NAME=ddos-cluster

# SSM Paths for External Secrets (helm values.externalSecrets)
SSM_API_KEY=/ddos/api-key
SSM_GMAIL_PASS=/ddos/gmail-password
SSM_SLACK_URL=/ddos/slack-webhook

# ===== ML / Detection =====
MODEL_PATH=production/xgboost_cic.pkl
CONTAMINATION=0.1
PPS_THRESHOLD_HIGH=50000
PPS_THRESHOLD_MEDIUM=25000

# ===== Mitigation =====
MITIGATION_DRY_RUN=true
AUTO_MITIGATE=false
CLOUD_PROVIDER=aws  # aws/gcp/azure/none

# ===== Compliance =====
GDPR_SALT=change-me-random-salt-for-pii-pseudonymization
ENABLE_PII_MASKING=true
DATA_RETENTION_DAYS=30

# ===== Training =====
TRAIN_SAMPLE_FRAC=0.1  # Memory-friendly default

