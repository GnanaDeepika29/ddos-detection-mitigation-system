# DDoS System Production Environment Variables
# Copy to .env and customize before production!

# API
API_KEY=your-super-secret-api-key-change-me
API_PORT=8000
API_HOST=0.0.0.0

# Kafka (bootstrap servers)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_FLOWS=network_flows_prod
KAFKA_TOPIC_ALERTS=ddos_alerts_prod

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-change-me

# ML Models
MODEL_PATH=models/production/xgboost_cic.pkl
ML_MODEL_PATH_ISOLATION_FOREST=models/production/isolation_forest.pkl

# Monitoring
PROMETHEUS_PORT=9091
GRAFANA_ADMIN_PASS=your-grafana-admin-password-change-me
GRAFANA_PORT=3000

# Mitigation
AUTO_MITIGATE=true
BLACKLIST_DURATION_SECONDS=3600
RATE_LIMIT_PPS=1000
CLOUD_PROVIDER=aws  # aws, azure, gcp, none

# Detection
DETECTION_WINDOW_SECONDS=5
DETECTION_THRESHOLD_PPS=50000

# Security/Compliance
DATA_RETENTION_DAYS=30
AUDIT_LOG_ENABLED=true
LOG_LEVEL=INFO

# Cloud Auth (AWS example)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
