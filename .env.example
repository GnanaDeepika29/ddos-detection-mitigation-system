# ============================================
# CLOUDSHIELD DDoS DETECTION SYSTEM
# Environment Configuration Template
# ============================================
# Copy this file to .env and modify values as needed
# Never commit .env to version control!

# ============================================
# APPLICATION SETTINGS
# ============================================

ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG_MODE=false
APP_VERSION=1.0.0
TIMEZONE=UTC
DATA_RETENTION_DAYS=30

# ============================================
# NETWORK & PACKET CAPTURE
# ============================================

COLLECTOR_INTERFACE=eth0
CAPTURE_FILTER=""
PROMISCUOUS_MODE=true
SNAPLEN=1518
FLOW_IDLE_TIMEOUT=30
FLOW_ACTIVE_TIMEOUT=60
MAX_FLOWS=100000

# ============================================
# KAFKA STREAMING CONFIGURATION
# ============================================

KAFKA_BOOTSTRAP_SERVERS=kafka:9092

KAFKA_TOPIC_FLOWS=network_flows
KAFKA_TOPIC_ALERTS=ddos_alerts
KAFKA_TOPIC_METRICS=detection_metrics
KAFKA_TOPIC_MITIGATION=mitigation_events

KAFKA_CONSUMER_GROUP=ddos-detection-group

KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SSL_CA_LOCATION=
KAFKA_SSL_CERTIFICATE_LOCATION=
KAFKA_SSL_KEY_LOCATION=

KAFKA_BATCH_SIZE=16384
KAFKA_LINGER_MS=5
KAFKA_COMPRESSION_TYPE=snappy
KAFKA_MAX_REQUEST_SIZE=1048576

# ============================================
# REDIS CONFIGURATION
# ============================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_KEY_TTL=300

RATE_LIMIT_DEFAULT_PPS=1000
RATE_LIMIT_BURST_MULTIPLIER=2

# ============================================
# DETECTION ENGINE CONFIGURATION
# ============================================

DETECTION_MODE=hybrid

DETECTION_WINDOW_SECONDS=5
DETECTION_SLIDE_SECONDS=1

DETECTION_THRESHOLD_PPS=10000
DETECTION_THRESHOLD_BPS=100000000
DETECTION_THRESHOLD_PPS_PER_IP=5000
DETECTION_THRESHOLD_CONN_PER_SEC=1000

ENTROPY_THRESHOLD=1.5              # Lower = more concentrated sources (possible DDoS)
ENTROPY_WINDOW_SECONDS=10
ENTROPY_MIN_SAMPLES=100

SYN_FLOOD_THRESHOLD_RATIO=0.8
SYN_FLOOD_MIN_RATE=1000

UDP_FLOOD_THRESHOLD_PPS=5000
ICMP_FLOOD_THRESHOLD_PPS=2000

HTTP_FLOOD_THRESHOLD_REQ_PER_SEC=500
HTTP_FLOOD_WINDOW_SECONDS=10

SLOWLORIS_MIN_CONNECTION_TIME=30
SLOWLORIS_MAX_REQUESTS_PER_CONN=5

# ============================================
# MACHINE LEARNING CONFIGURATION
# ============================================

ML_MODEL_PATH_ISOLATION_FOREST=/app/models/isolation_forest.pkl
ML_MODEL_PATH_AUTOENCODER=/app/models/lstm_autoencoder.h5
ML_MODEL_PATH_ONE_CLASS_SVM=/app/models/one_class_svm.pkl

ML_CONFIDENCE_THRESHOLD=0.7
ML_BATCH_SIZE=32
ML_SEQUENCE_LENGTH=10
ML_FEATURE_COUNT=25

ML_ONLINE_LEARNING=false
ML_RETRAIN_INTERVAL_HOURS=24
ML_RETRAIN_MIN_SAMPLES=10000

FEATURE_EXTRACTOR_INCLUDE_PAYLOAD=false
FEATURE_EXTRACTOR_MAX_PACKETS=1000

# ============================================
# MITIGATION CONFIGURATION
# ============================================

AUTO_MITIGATE=false
MITIGATION_DRY_RUN=true

CLOUD_PROVIDER=none

MITIGATION_ACTIONS=rate_limit,blackhole_ip,cloud_shield

RATE_LIMIT_PPS=500
RATE_LIMIT_DURATION_SECONDS=300
RATE_LIMIT_BURST=1000

BLACKLIST_DURATION_SECONDS=3600
BLACKLIST_MAX_IPS=1000

BGP_FLOWSPEC_ENABLED=false
BGP_FLOWSPEC_COMMUNITY=666:666
BGP_FLOWSPEC_NEXTHOP=192.168.1.1

SCRUBBER_ENABLED=false
SCRUBBER_API_ENDPOINT=https://scrubber.example.com/api
SCRUBBER_API_KEY=
SCRUBBER_REDIRECT_THRESHOLD=50000

# ============================================
# CLOUD PROVIDER CONFIGURATION
# ============================================

# ----- AWS -----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
AWS_VPC_ID=
AWS_SUBNET_IDS=
AWS_SECURITY_GROUP_IDS=

AWS_SHIELD_ENABLED=false
AWS_SHIELD_PROTECTION_GROUP_IDS=

AWS_WAF_ENABLED=false
AWS_WAF_WEB_ACL_ID=
AWS_WAF_RATE_LIMIT_RULE_PRIORITY=10

AWS_NETWORK_FIREWALL_ENABLED=false
AWS_NETWORK_FIREWALL_POLICY_ARN=

# ----- Azure -----
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_NETWORK_WATCHER_NAME=

AZURE_DDOS_PROTECTION_ENABLED=false
AZURE_DDOS_PROTECTION_PLAN_ID=

AZURE_FIREWALL_ENABLED=false
AZURE_FIREWALL_NAME=

# ----- GCP -----
GOOGLE_APPLICATION_CREDENTIALS=/app/config/gcp-credentials.json
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_NETWORK_NAME=default

GCP_CLOUD_ARMOR_ENABLED=false
GCP_CLOUD_ARMOR_POLICY_NAME=ddos-policy
GCP_CLOUD_ARMOR_RATE_LIMIT_THRESHOLD=1000

# ============================================
# MONITORING & METRICS
# ============================================

PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9091
PROMETHEUS_METRICS_PATH=/metrics

INFLUXDB_ENABLED=true
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=local-dev-token
INFLUXDB_ORG=ddos
INFLUXDB_BUCKET=metrics
INFLUXDB_BATCH_SIZE=5000
INFLUXDB_FLUSH_INTERVAL=10

GRAFANA_ENABLED=true
GRAFANA_URL=http://grafana:3000
GRAFANA_API_KEY=

# ============================================
# ALERTING & NOTIFICATIONS
# ============================================

ALERTMANAGER_ENABLED=true
ALERTMANAGER_URL=http://alertmanager:9093

SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=
SMTP_FROM=ddos-alerts@example.com
SMTP_TO=admin@example.com,security@example.com

SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXX
SLACK_CHANNEL=#ddos-alerts

PAGERDUTY_ENABLED=false
PAGERDUTY_INTEGRATION_KEY=
PAGERDUTY_SEVERITY=critical

WEBHOOK_ENABLED=false
WEBHOOK_URL=http://your-webhook-server.com/alert
WEBHOOK_HEADERS={"Content-Type": "application/json"}

ALERT_CRITICAL_PPS=100000
ALERT_WARNING_PPS=50000
ALERT_INFO_PPS=10000
ALERT_COOLDOWN_SECONDS=300

# ============================================
# API SERVER CONFIGURATION
# ============================================

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

API_AUTH_ENABLED=false
API_API_KEY=

API_JWT_SECRET_KEY=
API_JWT_ALGORITHM=HS256
API_JWT_EXPIRATION_MINUTES=30

API_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
API_CORS_ALLOW_CREDENTIALS=true
API_RATE_LIMIT=100

# ============================================
# DATABASE CONFIGURATION
# ============================================

POSTGRES_ENABLED=false
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ddos_system
POSTGRES_USER=ddos_user
POSTGRES_PASSWORD=secure_password_here
POSTGRES_SSL_MODE=disable
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# ============================================
# ELASTICSEARCH
# ============================================

ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_HOSTS=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=ddos-logs-
ELASTICSEARCH_VERIFY_CERTS=true

# ============================================
# PERFORMANCE TUNING
# ============================================

MAX_QUEUE_SIZE=10000
PARALLEL_WORKERS=4
PCAP_BUFFER_SIZE=2097152
MAX_MEMORY_BYTES=4294967296
CPU_AFFINITY=

# ============================================
# SECURITY & ENCRYPTION
# ============================================

ENABLE_PII_MASKING=true
PII_MASK_PATTERNS=ip_address,email,credit_card

INTERNAL_TLS_ENABLED=false
TLS_CERT_PATH=/app/certs/server.crt
TLS_KEY_PATH=/app/certs/server.key

AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=/app/logs/audit.log

# ============================================
# TESTING & SIMULATION (Development only)
# ============================================

SIMULATION_ENABLED=false
SIMULATION_TARGET_HOST=collector
SIMULATION_TARGET_PORT=80
SIMULATION_ATTACK_TYPE=benign
SIMULATION_ATTACK_RATE=1000
SIMULATION_DURATION=60
SIMULATION_THREADS=10

DATASET_PATH=/app/data/datasets/cic-ddos2019.parquet
DATASET_SAMPLE_SIZE=100000

# ============================================
# HEALTH CHECKS
# ============================================

HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_TIMEOUT_SECONDS=10
HEALTH_CHECK_DEPENDENCIES=kafka,redis,influxdb

# ============================================
# MISCELLANEOUS
# ============================================

TELEMETRY_ENABLED=false
USER_AGENT=CloudShield-DDoS-System/1.0
TEMP_DIR=/tmp/cloudshield
MAX_LOG_SIZE_MB=100
MAX_LOG_BACKUPS=5
